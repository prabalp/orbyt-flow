# Startup loads .env from the process working directory via github.com/joho/godotenv.
# When MCP/IDE cwd is not the repo root, point at this file explicitly:
# ORBYT_DOTENV=/path/to/orbyt-flow/.env

# HTTP port for cmd/server (must match the port in GOOGLE_REDIRECT_URI for OAuth)
PORT=8085

# Google OAuth2 (create credentials at https://console.cloud.google.com)
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:8085/oauth/google/callback

# Optional: workflow data directory (default ./data)
# FLOWENGINE_DATA_DIR=./data
